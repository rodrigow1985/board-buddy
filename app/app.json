{
  "expo": {
    "name": "Board Buddy",
    "slug": "board-buddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "boardbuddy",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Board Buddy usa el micrófono para detectar la palabra 'paso' y cambiar de turno automáticamente.",
        "NSSpeechRecognitionUsageDescription": "Board Buddy usa el reconocimiento de voz para detectar cuando un jugador dice 'paso'."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF6F0",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE"
      ],
      "package": "com.rodrigoweichert.boardbuddy"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF6F0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "root": "screens"
      },
      "eas": {
        "projectId": "f0c73239-70d8-4f3f-bb42-afc40bc9c8ba"
      }
    }
  }
}
